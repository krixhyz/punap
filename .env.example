ESEWA_STATUS_URL=https://rc.esewa.com.np/api/epay/transaction/status/
ESEWA_RESERVATION_MINUTES=15
ESEWA_SUCCESS_URL="${APP_URL}/payment/esewa/success"
ESEWA_FAILURE_URL="${APP_URL}/payment/esewa/failure"

KHALTI_BASE_URL=https://dev.khalti.com
KHALTI_INITIATE_URL="${KHALTI_BASE_URL}/api/v2/epayment/initiate/"
KHALTI_LOOKUP_URL="${KHALTI_BASE_URL}/api/v2/epayment/lookup/"
