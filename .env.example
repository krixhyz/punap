KHALTI_PUBLIC_KEY=
KHALTI_WEBSITE_URL="${APP_URL}"
KHALTI_RETURN_URL="${APP_URL}/payment/khalti/return"

# Backward-compatible aliases for existing local setups.
Khalti_live_secret_Key=
Khalti_live_public_Key=

VITE_APP_NAME="${APP_NAME}"


